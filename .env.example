# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Single app base URL used by frontend OAuth redirect and Supabase auth config.
# Example production value: https://expensio.your-domain.com
# Example local value: http://localhost:5173/
VITE_EXPENSIO_URL="https://expensio.your-domain.com"

# AI Budget Planner (OpenAI)
# IMPORTANT: Vite exposes VITE_* variables to the browser bundle.
# Use a restricted key and avoid production secrets in client-side apps.
VITE_OPENAI_BASE_URL="https://api.openai.com"
VITE_OPENAI_API_KEY="your-openai-api-key"
VITE_OPENAI_MODEL="gpt-4.1-mini"
