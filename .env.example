# Supabase Configuration
# Get these from your Supabase project settings
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Single app base URL used by frontend OAuth redirect and Supabase auth config.
# Example production value: https://expensio.your-domain.com
# Example local value: http://localhost:5173/
VITE_EXPENSIO_URL="https://expensio.your-domain.com"
